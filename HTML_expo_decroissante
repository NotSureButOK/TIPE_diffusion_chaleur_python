<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sinusoïde Amortie avec Enveloppe Exponentielle</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        canvas {
            background-color: #f9fafb; /* gray-50 */
            border-radius: 0.75rem; /* rounded-xl */
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        }
    </style>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

    <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-lg w-full max-w-4xl">
        <div class="text-center mb-6">
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-800">Sinusoïde Amortie et son Enveloppe</h1>
            <p class="text-gray-600 mt-2">Visualisation de <span class="font-mono text-indigo-600">y(t) = A * exp(-λt) * sin(ωt + φ)</span></p>
        </div>

        <!-- Canvas pour le graphique -->
        <div class="w-full aspect-w-16 aspect-h-9">
             <canvas id="waveCanvas"></canvas>
        </div>

        <!-- Contrôles -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
            <div>
                <label for="lambda" class="block text-sm font-medium text-gray-700">Amortissement (λ)</label>
                <input type="range" id="lambda" min="0" max="1" step="0.01" value="0.2" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
                <span id="lambda-value" class="text-sm text-gray-500">0.20</span>
            </div>
            <div>
                <label for="omega" class="block text-sm font-medium text-gray-700">Fréquence (ω)</label>
                <input type="range" id="omega" min="1" max="50" step="0.5" value="15" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
                 <span id="omega-value" class="text-sm text-gray-500">15.0</span>
            </div>
            <div>
                <label for="amplitude" class="block text-sm font-medium text-gray-700">Amplitude (A)</label>
                <input type="range" id="amplitude" min="0.1" max="1.5" step="0.05" value="1" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
                 <span id="amplitude-value" class="text-sm text-gray-500">1.00</span>
            </div>
        </div>

        <!-- Légende -->
        <div class="flex justify-center items-center space-x-6 mt-6 pt-4 border-t border-gray-200">
            <div class="flex items-center">
                <div class="w-4 h-0.5 bg-blue-600 mr-2"></div>
                <span class="text-sm text-gray-700">Fonction amortie</span>
            </div>
            <div class="flex items-center">
                 <div class="w-4 h-0.5 border-t-2 border-dashed border-gray-500 mr-2"></div>
                <span class="text-sm text-gray-700">Enveloppe exponentielle</span>
            </div>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('waveCanvas');
        const ctx = canvas.getContext('2d');

        // Références aux sliders et aux affichages de valeur
        const lambdaSlider = document.getElementById('lambda');
        const omegaSlider = document.getElementById('omega');
        const amplitudeSlider = document.getElementById('amplitude');
        const lambdaValueSpan = document.getElementById('lambda-value');
        const omegaValueSpan = document.getElementById('omega-value');
        const amplitudeValueSpan = document.getElementById('amplitude-value');

        let animationFrameId;

        function draw() {
            // Lire les valeurs actuelles des sliders
            const lambda = parseFloat(lambdaSlider.value);
            const omega = parseFloat(omegaSlider.value);
            const A = parseFloat(amplitudeSlider.value);
            const phi = 0; // Phase

            // Mettre à jour les labels
            lambdaValueSpan.textContent = lambda.toFixed(2);
            omegaValueSpan.textContent = omega.toFixed(1);
            amplitudeValueSpan.textContent = A.toFixed(2);

            // Ajuster la taille du canvas à son conteneur pour la haute résolution
            const dpr = window.devicePixelRatio || 1;
            const rect = canvas.getBoundingClientRect();
            canvas.width = rect.width * dpr;
            canvas.height = rect.height * dpr;
            ctx.scale(dpr, dpr);
            const { width, height } = rect;


            // Marges pour les axes
            const margin = { top: 20, right: 20, bottom: 40, left: 50 };
            const graphWidth = width - margin.left - margin.right;
            const graphHeight = height - margin.top - margin.bottom;

            // Effacer le canvas
            ctx.clearRect(0, 0, width, height);
            ctx.fillStyle = '#f9fafb';
            ctx.fillRect(0, 0, width, height);


            // Fonction pour mapper les coordonnées du graphique au canvas
            const xMax = 10;
            const yMax = A * 1.1; // Un peu de marge au-dessus de l'amplitude max

            const scaleX = (t) => margin.left + (t / xMax) * graphWidth;
            const scaleY = (y) => margin.top + graphHeight / 2 - (y / yMax) * (graphHeight / 2);

            // Dessiner les axes
            ctx.beginPath();
            ctx.strokeStyle = '#6b7280'; // gray-500
            ctx.lineWidth = 1;

            // Axe X
            ctx.moveTo(margin.left, margin.top + graphHeight / 2);
            ctx.lineTo(margin.left + graphWidth, margin.top + graphHeight / 2);
            // Axe Y
            ctx.moveTo(margin.left, margin.top);
            ctx.lineTo(margin.left, margin.top + graphHeight);
            ctx.stroke();

            // Labels des axes
            ctx.fillStyle = '#374151'; // gray-700
            ctx.font = '12px Inter';
            ctx.textAlign = 'center';
            ctx.fillText('Temps (t)', margin.left + graphWidth / 2, height - 10);
            ctx.save();
            ctx.rotate(-Math.PI / 2);
            ctx.fillText('Amplitude (y)', -(margin.top + graphHeight / 2), 20);
            ctx.restore();

            // Dessiner la fonction principale y(t)
            ctx.beginPath();
            ctx.strokeStyle = '#2563eb'; // blue-600
            ctx.lineWidth = 2;
            let firstPoint = true;
            for (let t = 0; t <= xMax; t += 0.01) {
                const y = A * Math.exp(-lambda * t) * Math.sin(omega * t + phi);
                if (firstPoint) {
                    ctx.moveTo(scaleX(t), scaleY(y));
                    firstPoint = false;
                } else {
                    ctx.lineTo(scaleX(t), scaleY(y));
                }
            }
            ctx.stroke();

            // Dessiner l'enveloppe exponentielle
            ctx.beginPath();
            ctx.strokeStyle = '#6b7280'; // gray-500
            ctx.lineWidth = 1.5;
            ctx.setLineDash([4, 4]); // Ligne en tirets

            // Enveloppe supérieure: A * exp(-lambda * t)
            firstPoint = true;
            for (let t = 0; t <= xMax; t += 0.05) {
                const env = A * Math.exp(-lambda * t);
                if (firstPoint) {
                    ctx.moveTo(scaleX(t), scaleY(env));
                    firstPoint = false;
                } else {
                    ctx.lineTo(scaleX(t), scaleY(env));
                }
            }

            // Enveloppe inférieure: -A * exp(-lambda * t)
            firstPoint = true;
            for (let t = 0; t <= xMax; t += 0.05) {
                const env = -A * Math.exp(-lambda * t);
                 if (firstPoint) {
                    ctx.moveTo(scaleX(t), scaleY(env));
                    firstPoint = false;
                } else {
                    ctx.lineTo(scaleX(t), scaleY(env));
                }
            }
            ctx.stroke();
            ctx.setLineDash([]); // Réinitialiser le style de ligne
        }

        // Fonction pour redessiner en continu
        function animate() {
            draw();
            animationFrameId = requestAnimationFrame(animate);
        }
        
        // Redessine lorsque les sliders changent
        lambdaSlider.addEventListener('input', draw);
        omegaSlider.addEventListener('input', draw);
        amplitudeSlider.addEventListener('input', draw);
        
        // Redessine si la fenêtre est redimensionnée
        window.addEventListener('resize', draw);

        // Lancement initial
        draw();

    </script>
</body>
</html>
